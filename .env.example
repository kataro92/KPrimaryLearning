# KV Primary Fun Learning — biến môi trường
# Sao chép file này thành `.env` và điền giá trị local:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Vite (client — chỉ biến có prefix VITE_ mới vào bundle trình duyệt)
# -----------------------------------------------------------------------------

# Base path khi build/chạy preview (GitHub Pages: /KPrimaryLearning/)
VITE_BASE_PATH=/

# Cổng dev server (tùy chọn)
VITE_DEV_PORT=5173

# Bật/tắt TTS neural local (Transformers.js). false = chỉ Web Speech
VITE_NEURAL_TTS_ENABLED=true

# Model Hugging Face ONNX cho TTS tiếng Việt
VITE_TTS_MODEL_ID=Xenova/mms-tts-vie

# -----------------------------------------------------------------------------
# Script Node (không expose ra trình duyệt)
# -----------------------------------------------------------------------------

# Token Sketchfab — lấy tại Settings → Password → API token
# Dùng cho: npm run fetch:models
SKETCHFAB_API_TOKEN=
